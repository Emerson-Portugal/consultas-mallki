---
// stylesheet
import "../styles/global.css";

// components
import BaseHead from "../components/global/BaseHead.astro";
import Wrapper from "../components/global/Wrapper.astro";
import NavBar from "../components/global/Navigation.astro";
import Footer from "../components/global/Footer.astro";

// assets
import "@fontsource-variable/inter/index.css";
import "@fontsource/road-rage";
import "@fontsource-variable/jetbrains-mono";

// props
const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth scroll-pt-[calc(7.5rem+env(safe-area-inset-top,0px))]">
  <BaseHead pageTitle={title} />
  <body
    class="font-sans-pro min-h-screen bg-base-100 antialiased text-base-900"
  >
    <Wrapper>
      <NavBar />
      <main class="flex flex-col gap-12">
        <slot />
      </main>
      <Footer />
    </Wrapper>
  </body>
</html>
