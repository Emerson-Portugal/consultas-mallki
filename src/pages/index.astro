---
import Layout from "../layouts/Layout.astro";
import Container from "../components/elements/Container.astro";
---

<Layout title="Consulta de comprobante">
  <Container variant="xl" class="flex flex-col items-center gap-10 pb-24 pt-4 sm:pt-6">
    <div
      id="intro-descarga"
      class="flex max-w-2xl cursor-default flex-col gap-5 px-2 text-center sm:max-w-3xl sm:px-0"
      role="region"
      aria-label="Instrucciones de descarga"
    >
      <h1 class="font-sans-pro text-4xl font-semibold leading-tight tracking-tight text-base-900 sm:text-5xl md:text-[3rem] md:leading-[1.15]">
        Descarga tu comprobante
      </h1>
      <p class="font-sans-pro text-lg leading-relaxed text-base-700 sm:text-xl md:text-[1.25rem] md:leading-relaxed">
        Ingresa la serie, el correlativo y el código de seguridad de 3 caracteres tal como figuran en tu ticket. Se
        descargará un ZIP con el PDF, el XML UBL y, si ya está disponible, la constancia de recepción SUNAT (CDR).
      </p>
    </div>

    <form
      id="form-consulta"
      class="font-sans-pro flex w-full max-w-md flex-col gap-6"
      novalidate
    >
      <div class="flex flex-col gap-2 text-left">
        <span class="text-sm font-medium tracking-normal text-base-600 sm:text-base">Número SUNAT</span>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
          <div class="flex min-w-0 flex-col gap-2">
            <label for="serie" class="text-12 font-medium text-base-500">Serie</label>
            <input
              id="serie"
              name="serie"
              type="text"
              required
              maxlength="10"
              autocomplete="off"
              placeholder="Ej. F001, FMK1"
              class="w-full min-w-0 rounded border border-base-500 bg-base-200/80 px-4 py-3.5 text-base font-normal uppercase tracking-wider text-base-900 placeholder:normal-case placeholder:tracking-normal placeholder:text-base-500 focus:border-base-700 focus:outline-none focus:ring-1 focus:ring-base-700 sm:text-lg"
            />
          </div>
          <div class="flex min-w-0 flex-col gap-2">
            <label for="correlativo" class="text-12 font-medium text-base-500">Correlativo</label>
            <input
              id="correlativo"
              name="correlativo"
              type="text"
              inputmode="numeric"
              required
              minlength="8"
              maxlength="8"
              autocomplete="off"
              placeholder="Ej. 00000005"
              class="w-full min-w-0 rounded border border-base-500 bg-base-200/80 px-4 py-3.5 text-base font-normal tracking-normal text-base-900 placeholder:text-base-500 focus:border-base-700 focus:outline-none focus:ring-1 focus:ring-base-700 sm:text-lg"
            />
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-2 text-left">
        <label for="codigo" class="text-sm font-medium tracking-normal text-base-600 sm:text-base"
          >Código de seguridad</label
        >
        <input
          id="codigo"
          name="codigo"
          type="text"
          required
          minlength="3"
          maxlength="3"
          autocomplete="off"
          placeholder="Ej. A1R"
          class="w-full rounded border border-base-500 bg-base-200/80 px-4 py-3.5 text-base font-normal uppercase tracking-wider text-base-900 placeholder:normal-case placeholder:tracking-normal placeholder:text-base-500 focus:border-base-700 focus:outline-none focus:ring-1 focus:ring-base-700 sm:text-lg"
        />
      </div>
      <p id="mensaje-error" class="hidden text-sm text-red-400 sm:text-base" role="alert"></p>
      <button
        type="submit"
        id="btn-descargar"
        class="rounded bg-base-900 px-6 py-3.5 text-base font-semibold tracking-normal text-base-100 hover:bg-base-800 focus:outline-none focus:ring-2 focus:ring-base-700 disabled:cursor-not-allowed disabled:opacity-60 sm:text-lg"
      >
        Descargar ZIP
      </button>
      <div id="fallback-nueva-pestana" class="hidden flex flex-col items-center gap-3" aria-live="polite">
        <p class="text-sm text-base-500 text-center max-w-md leading-relaxed sm:text-base">
          Puede intentar abrir el mismo enlace en una nueva pestaña; a veces el navegador permite la descarga así.
        </p>
        <button
          type="button"
          id="btn-nueva-pestana"
          class="text-sm font-medium tracking-normal text-base-600 underline underline-offset-4 hover:text-base-800 sm:text-base"
        >
          Abrir descarga en nueva pestaña
        </button>
      </div>
    </form>
  </Container>
</Layout>

<script>
  import {
    buildPublicZipUrl,
    componerNumeroSunat,
    descargarComprobanteZip,
    validarSerieCorrelativoCodigo,
  } from "../lib/descargaComprobante";

  const intro = document.getElementById("intro-descarga");
  intro?.addEventListener(
    "pointerdown",
    () => {
      window.dispatchEvent(new CustomEvent("mallki:hide-header"));
    },
    { passive: true }
  );

  const form = document.getElementById("form-consulta") as HTMLFormElement;
  const errEl = document.getElementById("mensaje-error") as HTMLParagraphElement;
  const btn = document.getElementById("btn-descargar") as HTMLButtonElement;
  const btnNueva = document.getElementById("btn-nueva-pestana") as HTMLButtonElement;
  const fallbackNueva = document.getElementById("fallback-nueva-pestana") as HTMLDivElement;

  function setFallbackVisible(show: boolean) {
    fallbackNueva.classList.toggle("hidden", !show);
  }

  function setError(msg: string | null) {
    if (!msg) {
      errEl.textContent = "";
      errEl.classList.add("hidden");
      return;
    }
    errEl.textContent = msg;
    errEl.classList.remove("hidden");
  }

  function leerCampos() {
    const serie = (document.getElementById("serie") as HTMLInputElement).value;
    const correlativo = (document.getElementById("correlativo") as HTMLInputElement).value;
    const codigo = (document.getElementById("codigo") as HTMLInputElement).value;
    const numero = componerNumeroSunat(serie, correlativo);
    return { serie, correlativo, numero, codigo };
  }

  const serieInput = document.getElementById("serie") as HTMLInputElement;
  const correlativoInput = document.getElementById("correlativo") as HTMLInputElement;

  serieInput?.addEventListener("input", () => {
    const pos = serieInput.selectionStart ?? serieInput.value.length;
    serieInput.value = serieInput.value.toUpperCase();
    serieInput.setSelectionRange(pos, pos);
    setFallbackVisible(false);
  });

  correlativoInput?.addEventListener("input", () => {
    correlativoInput.value = correlativoInput.value.replace(/\D/g, "").slice(0, 8);
    setFallbackVisible(false);
  });

  function alCambiarCampos() {
    setFallbackVisible(false);
  }
  document.getElementById("codigo")?.addEventListener("input", alCambiarCampos);

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    setError(null);
    setFallbackVisible(false);

    const { serie, correlativo, numero, codigo } = leerCampos();
    const v = validarSerieCorrelativoCodigo(serie, correlativo, codigo);
    if (v) {
      setError(v);
      return;
    }

    btn.disabled = true;
    const res = await descargarComprobanteZip(numero, codigo);
    btn.disabled = false;

    if (!res.ok) {
      setError(res.mensaje);
      setFallbackVisible(!!res.mostrarAlternativaNuevaPestana);
      return;
    }
    setError(null);
    setFallbackVisible(false);
  });

  btnNueva?.addEventListener("click", () => {
    const { serie, correlativo, numero, codigo } = leerCampos();
    const v = validarSerieCorrelativoCodigo(serie, correlativo, codigo);
    if (v) {
      setError(v);
      return;
    }
    setError(null);
    const url = buildPublicZipUrl(numero, codigo);
    window.open(url, "_blank", "noopener,noreferrer");
  });
</script>
